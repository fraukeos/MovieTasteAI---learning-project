# Vorlage für die .env-Datei.
# 1. Diese Datei kopieren und als ".env" speichern (ohne ".example")
# 2. Eigenen Key eintragen
# 3. Die echte .env-Datei wird NIE committet (siehe .gitignore)

# kostenlos unter https://www.themoviedb.org/settings/api (Anmeldung erforderlich)
TMDB_API_KEY=dein_tmdb_api_key_hier